{
  "name": "context-awesome",
  "version": "1.0.0",
  "description": "CLI + MCP server for curated awesome-list context",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "context-awesome": "build/index.js",
    "context-awesome-mcp": "build/index.js"
  },
  "files": ["build", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsc && chmod +x build/index.js",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": ["mcp", "model-context-protocol", "awesome-lists", "documentation", "cli"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^22.10.5",
    "@types/yargs": "^17.0.32",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": { "node": ">=18.0.0" }
}
